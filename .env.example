# XPayments — Environment Variables
# Copy to .env (or .env.local) and fill in.

# Backend API base URL (production)
NEXT_PUBLIC_API_URL=https://api.xpayments.digital/api/v1

# App name (shown in metadata, manifest, sidebar)
NEXT_PUBLIC_APP_NAME=XPayments

# Environment: production | staging | development
NEXT_PUBLIC_ENV=production

# Use mock data layer instead of hitting the real API.
# Set to "false" once the backend is reachable in production.
NEXT_PUBLIC_USE_MOCK=true

# Local SQLite database (Prisma) — used only by local dev tooling
DATABASE_URL=file:./db/custom.db
